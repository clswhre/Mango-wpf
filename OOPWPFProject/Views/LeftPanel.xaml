<UserControl x:Class="OOPWPFProject.Views.LeftPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml" xmlns:viewmodels="clr-namespace:OOPWPFProject.ViewModels">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  BorderBrush="Transparent"
                  BorderThickness="0,0,1,0">

        <StackPanel Margin="20" HorizontalAlignment="Stretch">

            <ui:TextBlock Text="Назва міста *" Margin="0,0,0,4" />
            <ui:TextBox x:Name="CityTextBox"
                        Text="{Binding LeftPanelViewModel.NewName, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="Львів"
                        Margin="0,0,0,16"/>

            <ui:TextBlock Text="Країна *" Margin="0,0,0,4" />
            <ui:TextBox x:Name="CountryTextBox"
                        Text="{Binding LeftPanelViewModel.NewCountry, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="Україна"
                        Margin="0,0,0,16"
                        AutomationProperties.IsRequiredForForm="True"/>

            <ui:TextBlock Text="Опис *" Margin="0,0,0,4" />
            <ui:TextBox x:Name="DescriptionTextBox"
                        Text="{Binding LeftPanelViewModel.NewDescription, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="Це місто кави, місто тисячі левів,&#x0a;місто джазу, дощу,шоколаду, терас&#x0a;і пристрасного танго."
                        TextWrapping="Wrap"
                        AcceptsReturn="True"
                        MinHeight="70"
                        Margin="0,0,0,16"/>

            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <ui:TextBlock Text="Дата відвідування" Margin="0,0,0,4"/>
                    <DatePicker x:Name="DatePickerBox"  SelectedDate="{Binding LeftPanelViewModel.NewVisitDate}" HorizontalAlignment="Stretch"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <ui:TextBlock Text="Рейтинг" Margin="0,0,0,4"/>
                    <ui:RatingControl x:Name="Rating" Value="{Binding LeftPanelViewModel.NewRating, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HalfStarEnabled="False"/>
                </StackPanel>

            </Grid>

            <StackPanel>
                <ui:TextBlock>
                    Тип місця
                </ui:TextBlock>
                <ComboBox Margin="0,0,0,20"
                          ItemsSource="{Binding LeftPanelViewModel.PlaceTypes}"
                          SelectedItem="{Binding LeftPanelViewModel.SelectedPlaceType, Mode=TwoWay}" />
            </StackPanel>

            <!-- Поля для Historical -->
            <StackPanel Visibility="{Binding LeftPanelViewModel.IsHistoricalSelected}" Margin="0,0,0,12">
                <ui:TextBlock Text="Рік побудови" Margin="0,0,0,4" />
                <ui:TextBox Text="{Binding LeftPanelViewModel.HistoricalYearBuilt, Mode=TwoWay}"/>

                <ui:TextBlock Text="Значимість (1-10)" Margin="0,8,0,4" />

                <Slider TickPlacement="Both"
                        Minimum="1" Maximum="10"
                        IsSnapToTickEnabled="True"
                        TickFrequency="1"
                        Value="{Binding LeftPanelViewModel.HistoricalSignificance, Mode=TwoWay}" />
            </StackPanel>

            <!-- Поля для Natural -->
            <StackPanel Visibility="{Binding LeftPanelViewModel.IsNaturalSelected}" Margin="0,0,0,12">
                <ui:TextBlock Text="Рік утворення" Margin="0,0,0,4" />
                <ui:TextBox Text="{Binding LeftPanelViewModel.NaturalYearFormed, Mode=TwoWay}" />
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <ui:TextBlock Text="Під захистом" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <CheckBox IsChecked="{Binding LeftPanelViewModel.NaturalProtectedStatus, Mode=TwoWay}" />
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <CheckBox IsChecked="{Binding LeftPanelViewModel.IsNewPlaceVisited}" />
                <TextBlock Text="Місто відвідане" VerticalAlignment="Center"  />
            </StackPanel>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="5*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                
                <!-- КНОПКА "Додати місце" -->
                <ui:Button Grid.Column="0"
                           HorizontalAlignment="Stretch"
                           Appearance="Success"
                           Icon="{ui:SymbolIcon Symbol=Add20}"
                           Command="{Binding LeftPanelViewModel.AddPlaceCommand}" 
                           Content="{Binding LeftPanelViewModel.AddPlaceButtonText, Mode=OneWay}"  />

                <ui:Button Grid.Column="2"
                           Appearance="Secondary"
                           HorizontalAlignment="Stretch"
                           Icon="{ui:SymbolIcon Symbol=Broom20}"
                           Command="{Binding LeftPanelViewModel.ClearFormCommand}" />
            </Grid>
            
            <ui:TextBlock Opacity="0.6">
                * - обов'язкові для заповнення поля
            </ui:TextBlock>

            <Expander Header="Додаткові інструменти" IsExpanded="False" Margin="0,8,0,0" Visibility="{Binding PlaceListViewModel.IsAnyPlaces}">

                <StackPanel>
                    <Expander Header="Пошук за індексом" IsExpanded="False" Margin="0,8,0,0">
                        <StackPanel>
                            <ui:TextBlock Text="Введіть індекс" Margin="0,0,0,4" />
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <ui:NumberBox Grid.Column="0"
                                              Value="{Binding LeftPanelViewModel.IndexToShow, UpdateSourceTrigger=PropertyChanged}"
                                              Minimum="0"
                                              HorizontalAlignment="Stretch" />

                                <ui:Button Grid.Column="2"
                                           Appearance="Secondary"
                                           Icon="{ui:SymbolIcon Symbol=Search20}"
                                           Command="{Binding LeftPanelViewModel.ShowByIndexCommand}"
                                           Padding="12,8" />
                            </Grid>

                            <ui:TextBlock Text="Результат:" Margin="0,0,0,4" Opacity="0.7" FontSize="12" />
                            <TextBlock Text="{Binding LeftPanelViewModel.PlaceAtIndexDisplay}"
                                       TextWrapping="Wrap"
                                       MinHeight="40"
                                       Padding="8" />
                        </StackPanel>
                    </Expander>

                    <Expander Header="Перевантажені оператори" IsExpanded="False" Margin="0,8,0,0">
                        <StackPanel>
                            <TextBlock> 1 об'єкт</TextBlock>
                            <ComboBox ItemsSource="{Binding LeftPanelViewModel.Places}" DisplayMemberPath="Name" SelectedItem="{Binding LeftPanelViewModel.SelectedObject1}" Margin="0,0,0,5" />

                            <TextBlock> 2 об'єкт</TextBlock>
                            <ComboBox ItemsSource="{Binding LeftPanelViewModel.Places}" DisplayMemberPath="Name" SelectedItem="{Binding LeftPanelViewModel.SelectedObject2}" Margin="0,0,0,5" />

                            <TextBlock> Операція</TextBlock>
                            <ComboBox ItemsSource="{Binding LeftPanelViewModel.Operators}" SelectedItem="{Binding LeftPanelViewModel.SelectedOperator}" Margin="0,0,0,5" />

                            <ui:Button Appearance="Primary" Command="{Binding LeftPanelViewModel.OverridedOperatorActon}" HorizontalAlignment="Stretch" Margin="0,5,0,5">
                                Виконати операцію
                            </ui:Button>

                            <TextBlock Text="Результат:" Margin="0,5,0,2" Opacity="0.7" FontSize="12" />
                            <TextBlock Text="{Binding LeftPanelViewModel.OperatorResult}" TextWrapping="Wrap" MinHeight="40" Background="#1AFFFFFF" Padding="8" />
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </Expander>
        </StackPanel>
    </ScrollViewer>
</UserControl>

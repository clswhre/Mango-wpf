<UserControl
	x:Class="OOPWPFProject.Views.MainContent"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
>
	<Grid Margin="10">
		<TabControl>
			<TabItem Visibility="{Binding PlaceListViewModel.IsPlannedPlaceExists}">
				<TabItem.Header>
					<StackPanel Orientation="Horizontal">
						<ui:SymbolIcon Symbol="Airplane20" Margin="0,0,6,0" />
						<TextBlock Text="Заплановані місця" VerticalAlignment="Center" />
					</StackPanel>
				</TabItem.Header>
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="3*" MinHeight="200" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="2*" MinHeight="250" />
					</Grid.RowDefinitions>

					<Grid Grid.Row="0">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="389*" />
							<ColumnDefinition Width="54*" />
							<ColumnDefinition Width="335*" />
						</Grid.ColumnDefinitions>
						<ui:DataGrid
							ItemsSource="{Binding PlaceListViewModel.PlannedPlaces}"
							SelectedItem="{Binding PlaceListViewModel.SelectedPlace}"
							Visibility="{Binding PlaceListViewModel.IsPlannedPlaceExists}"
							AutoGenerateColumns="False"
							IsReadOnly="True"
							SelectionMode="Single"
							HeadersVisibility="Column"
							Margin="0,0,0,16"
							Grid.ColumnSpan="3"
						>
							<DataGrid.Columns>
								<DataGridTemplateColumn
									Header="Місто"
									Width="*"
									SortMemberPath="NameOfPlace"
								>
									<DataGridTemplateColumn.CellTemplate>
										<DataTemplate>
											<StackPanel Orientation="Horizontal">
												<ui:SymbolIcon
													x:Name="StarIcon"
													Symbol="Star20"
													Filled="True"
													Foreground="#FFD700"
													Margin="0,0,6,0"
													Visibility="Collapsed"
												/>
												<TextBlock
													Text="{Binding Name}"
													VerticalAlignment="Center"
												/>
											</StackPanel>
											<DataTemplate.Triggers>
												<DataTrigger
													Binding="{Binding IsHighlyRated}"
													Value="True"
												>
													<Setter
														TargetName="StarIcon"
														Property="Visibility"
														Value="Visible"
													/>
												</DataTrigger>
											</DataTemplate.Triggers>
										</DataTemplate>
									</DataGridTemplateColumn.CellTemplate>
								</DataGridTemplateColumn>
								<DataGridTextColumn
									Header="Країна"
									Binding="{Binding Country}"
									Width="*"
								/>
								<DataGridTextColumn
									Header="Опис"
									Binding="{Binding Description, Mode=OneWay}"
									Width="1.5*"
								/>
								<DataGridTextColumn
									Header="Дата"
									Binding="{Binding Date, Mode=OneWay, StringFormat='{}{0:dd/MM/yyyy}'}"
									Width="*"
								/>
								<DataGridTextColumn
									Header="Рейтинг"
									Binding="{Binding Rating, Mode=OneWay}"
									Width="*"
								/>
							</DataGrid.Columns>
						</ui:DataGrid>

						<ui:TextBlock
							FontSize="48"
							FontWeight="Light"
							HorizontalAlignment="Left"
							VerticalAlignment="Center"
							Visibility="{Binding PlaceListViewModel.IsPlannedAddPlaceTextVisible}"
							Grid.ColumnSpan="3"
						>
                            Додайте місце для перегляду
                        </ui:TextBlock>
					</Grid>

					<GridSplitter
						Grid.Row="1"
						Height="5"
						HorizontalAlignment="Stretch"
						VerticalAlignment="Center"
						Background="Transparent"
						Cursor="SizeNS"
						Margin="0,4,0,4"
					/>

					<Border
						Grid.Row="2"
						Padding="16"
						Margin="0,8,0,0"
						Visibility="{Binding PlaceListViewModel.IsSelectedPlaceExists}"
					>
						<TabControl>
							<TabItem>
								<TabItem.Header>
									<StackPanel Orientation="Horizontal">
										<ui:SymbolIcon Symbol="Info20" Margin="0,0,6,0" />
										<TextBlock Text="Деталі" VerticalAlignment="Center" />
									</StackPanel>
								</TabItem.Header>
								<Grid DataContext="{Binding PlaceListViewModel.DetailsTab}">
									<Grid.RowDefinitions>
										<RowDefinition Height="Auto" />
										<RowDefinition Height="*" />
									</Grid.RowDefinitions>
									<Grid Margin="0,0,0,12">
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="*" />
											<ColumnDefinition Width="Auto" />
											<ColumnDefinition Width="8" />
											<ColumnDefinition Width="Auto" />
										</Grid.ColumnDefinitions>
										<ui:TextBlock
											Grid.Column="0"
											Text="Деталі місця"
											FontSize="16"
											FontWeight="Bold"
											VerticalAlignment="Center"
										/>
										<ui:Button
											Grid.Column="1"
											Appearance="Caution"
											Icon="{ui:SymbolIcon Symbol=Edit20}"
											Command="{Binding ToggleEditCommand}"
										>
                                            Редагувати
                                        </ui:Button>
										<ui:Button
											Grid.Column="3"
											Appearance="Danger"
											Command="{Binding DeletePlaceCommand}"
											Icon="{ui:SymbolIcon Symbol=Delete20}"
										>
                                            Видалити обраний запис
                                        </ui:Button>
									</Grid>

									<ScrollViewer
										Grid.Row="1"
										VerticalScrollBarVisibility="Auto"
										CanContentScroll="True"
									>
										<StackPanel
											Margin="0,0,12,0"
											IsEnabled="{Binding IsEditing}"
										>
											<Grid Margin="0,0,0,8">
												<Grid.ColumnDefinitions>
													<ColumnDefinition Width="*" />
													<ColumnDefinition Width="12" />
													<ColumnDefinition Width="*" />
												</Grid.ColumnDefinitions>

												<StackPanel Grid.Column="0">
													<ui:TextBlock Text="Назва *" Margin="0,0,0,4" />
													<ui:TextBox Text="{Binding EditedName, UpdateSourceTrigger=PropertyChanged}" />
												</StackPanel>

												<StackPanel Grid.Column="2">
													<ui:TextBlock
														Text="Країна *"
														Margin="0,0,0,4"
													/>
													<ui:TextBox Text="{Binding EditedCountry, UpdateSourceTrigger=PropertyChanged}" />
												</StackPanel>
											</Grid>

											<ui:TextBlock Text="Опис *" Margin="0,0,0,4" />
											<ui:TextBox
												Text="{Binding EditedDescription, UpdateSourceTrigger=PropertyChanged}"
												AcceptsReturn="True"
												TextWrapping="Wrap"
												MinHeight="60"
												Margin="0,0,0,8"
											/>

											<ui:TextBlock
												Text="Дата відвідування"
												Margin="0,0,0,4"
											/>
											<DatePicker
												SelectedDate="{Binding EditedVisitDate}"
												Margin="0,0,0,8"
											/>

											<ui:TextBlock Text="Рейтинг" Margin="0,0,0,4" />
											<ui:RatingControl
												Value="{Binding EditedRating, Mode=TwoWay, TargetNullValue=0}"
												HalfStarEnabled="False"
												Margin="0,0,0,8"
											/>

											<StackPanel Orientation="Horizontal" Margin="0,0,0,8">
												<CheckBox IsChecked="{Binding EditedIsVisited}" />
												<TextBlock
													Text="Місто відвідане"
													VerticalAlignment="Center"
													Margin="8,0,0,0"
												/>
											</StackPanel>

											<StackPanel
												Visibility="{Binding IsEditHistoricalVisible}"
												Margin="0,0,0,8"
											>
												<ui:TextBlock
													Text="Рік побудови"
													Margin="0,0,0,4"
												/>
												<ui:TextBox Text="{Binding EditedHistoricalYearBuilt, Mode=TwoWay}" />

												<ui:TextBlock
													Text="Значимість (1-10)"
													Margin="0,8,0,4"
												/>
												<Slider
													TickPlacement="Both"
													Minimum="1"
													Maximum="10"
													IsSnapToTickEnabled="True"
													TickFrequency="1"
													Value="{Binding EditedHistoricalSignificance, Mode=TwoWay}"
												/>
											</StackPanel>

											<StackPanel
												Visibility="{Binding IsEditNaturalVisible}"
												Margin="0,0,0,8"
											>
												<ui:TextBlock
													Text="Рік утворення"
													Margin="0,0,0,4"
												/>
												<ui:TextBox Text="{Binding EditedNaturalYearFormed, Mode=TwoWay}" />
												<StackPanel
													Orientation="Horizontal"
													Margin="0,8,0,0"
												>
													<ui:TextBlock
														Text="Під захистом"
														VerticalAlignment="Center"
														Margin="0,0,8,0"
													/>
													<CheckBox IsChecked="{Binding EditedNaturalProtectedStatus, Mode=TwoWay}" />
												</StackPanel>
											</StackPanel>

											<StackPanel
												Orientation="Horizontal"
												Margin="0,8,0,0"
												IsEnabled="{Binding IsEditing}"
											>
												<ui:Button
													Appearance="Primary"
													Command="{Binding Path=SaveEditCommand}"
												>
                                                    Зберегти
                                                </ui:Button>
												<ui:Button
													Appearance="Secondary"
													Command="{Binding Path=CancelEditCommand}"
													Margin="8,0,0,0"
												>
                                                    Скасувати
                                                </ui:Button>
											</StackPanel>
										</StackPanel>
									</ScrollViewer>
								</Grid>
							</TabItem>

							<TabItem>
								<TabItem.Header>
									<StackPanel Orientation="Horizontal">
										<ui:SymbolIcon Symbol="WeatherHaze20" Margin="0,0,6,0" />
										<TextBlock Text="Погода" VerticalAlignment="Center" />
									</StackPanel>
								</TabItem.Header>
								<StackPanel
									Orientation="Horizontal"
									HorizontalAlignment="Left"
									VerticalAlignment="Center"
									Margin="0,8,0,0"
									DataContext="{Binding PlaceListViewModel.WeatherTab}"
								>
									<TextBlock
										Text="{Binding WeatherSummary}"
										Margin="0,0,8,0"
										VerticalAlignment="Center"
									/>
									<Image
										Source="{Binding WeatherIconPath, TargetNullValue={x:Null}}"
										Width="40"
										Height="40"
									/>
								</StackPanel>
							</TabItem>
							<TabItem>
								<TabItem.Header>
									<StackPanel Orientation="Horizontal">
										<ui:SymbolIcon Symbol="Chat20" Margin="0,0,6,0" />
										<TextBlock Text="Відгуки" VerticalAlignment="Center" />
									</StackPanel>
								</TabItem.Header>
								<StackPanel
									Margin="0,12,0,0"
									DataContext="{Binding PlaceListViewModel.ReviewsTab}"
								>
									<ScrollViewer
										VerticalScrollBarVisibility="Auto"
										MaxHeight="200"
									>
										<ItemsControl ItemsSource="{Binding Reviews}">
											<ItemsControl.ItemTemplate>
												<DataTemplate>
													<Border
														Padding="8"
														Margin="0,0,0,6"
														Background="#1AFFFFFF"
														CornerRadius="6"
													>
														<DockPanel LastChildFill="True">
															<StackPanel
																Orientation="Horizontal"
																HorizontalAlignment="Right"
																DockPanel.Dock="Right"
															>
																<TextBlock
																	Text="{Binding Value, StringFormat='{}{0:0.0}'}"
																	Margin="0,0,8,0"
																	VerticalAlignment="Center"
																/>
																<Button
																	Padding="8,4"
																	Margin="6,0,0,0"
																	Command="{Binding DataContext.RemoveReviewCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
																	CommandParameter="{Binding Key}"
																>
                                                                    Видалити
                                                                </Button>
															</StackPanel>
															<TextBlock
																Text="{Binding Key}"
																TextWrapping="Wrap"
																VerticalAlignment="Center"
																Margin="0,0,10,0"
															/>
														</DockPanel>
													</Border>
												</DataTemplate>
											</ItemsControl.ItemTemplate>
										</ItemsControl>
									</ScrollViewer>

									<StackPanel Orientation="Vertical" Margin="0,8,0,0">
										<ui:TextBox
											Text="{Binding NewReviewText, UpdateSourceTrigger=PropertyChanged}"
											PlaceholderText="Напишіть відгук..."
											AcceptsReturn="True"
											MinHeight="60"
										/>
										<StackPanel Orientation="Horizontal" Margin="0,8,0,0">
											<ui:RatingControl
												Value="{Binding NewReviewRating, Mode=TwoWay, TargetNullValue=0}"
												HalfStarEnabled="False"
											/>
											<ui:Button
												Appearance="Success"
												Margin="8,0,0,0"
												Command="{Binding AddReviewCommand}"
											>
                                                Додати відгук
                                            </ui:Button>
										</StackPanel>
									</StackPanel>
								</StackPanel>
							</TabItem>
						</TabControl>
					</Border>
				</Grid>
			</TabItem>

			<TabItem Visibility="{Binding PlaceListViewModel.IsVisitedPlaceExists}">
				<TabItem.Header>
					<StackPanel Orientation="Horizontal">
						<ui:SymbolIcon Symbol="Location20" Margin="0,0,6,0" />
						<TextBlock Text="Відвідані місця" VerticalAlignment="Center" />
					</StackPanel>
				</TabItem.Header>

				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="3*" MinHeight="200" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="2*" MinHeight="250" />
					</Grid.RowDefinitions>

					<Grid Grid.Row="0">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="3*" />
							<ColumnDefinition Width="778*" />
						</Grid.ColumnDefinitions>
						<ui:DataGrid
							x:Name="PlannedPlacesDataGrid"
							ItemsSource="{Binding PlaceListViewModel.VisitedPlaces}"
							SelectedItem="{Binding PlaceListViewModel.SelectedPlace}"
							Visibility="{Binding PlaceListViewModel.IsVisitedPlaceExists}"
							AutoGenerateColumns="False"
							IsReadOnly="True"
							SelectionMode="Single"
							HeadersVisibility="Column"
							Margin="0,0,0,16"
							Grid.ColumnSpan="2"
						>
							<DataGrid.Columns>
								<DataGridTemplateColumn
									Header="Місто"
									Width="*"
									SortMemberPath="NameOfPlace"
								>
									<DataGridTemplateColumn.CellTemplate>
										<DataTemplate>
											<StackPanel Orientation="Horizontal">
												<ui:SymbolIcon
													x:Name="StarIcon"
													Symbol="Star20"
													Filled="True"
													Foreground="#FFD700"
													Margin="0,0,6,0"
													Visibility="Collapsed"
												/>
												<TextBlock
													Text="{Binding Name}"
													VerticalAlignment="Center"
												/>
											</StackPanel>
											<DataTemplate.Triggers>
												<DataTrigger
													Binding="{Binding IsHighlyRated}"
													Value="True"
												>
													<Setter
														TargetName="StarIcon"
														Property="Visibility"
														Value="Visible"
													/>
												</DataTrigger>
											</DataTemplate.Triggers>
										</DataTemplate>
									</DataGridTemplateColumn.CellTemplate>
								</DataGridTemplateColumn>
								<DataGridTextColumn
									Header="Країна"
									Binding="{Binding Country}"
									Width="*"
								/>
								<DataGridTextColumn
									Header="Опис"
									Binding="{Binding Description, Mode=OneWay}"
									Width="1.5*"
								/>
								<DataGridTextColumn
									Header="Дата"
									Binding="{Binding Date, Mode=OneWay, StringFormat='{}{0:dd/MM/yyyy}'}"
									Width="*"
								/>
								<DataGridTextColumn
									Header="Рейтинг"
									Binding="{Binding Rating, Mode=OneWay}"
									Width="*"
								/>
							</DataGrid.Columns>
						</ui:DataGrid>

						<ui:TextBlock
							FontSize="48"
							FontWeight="Light"
							HorizontalAlignment="Center"
							VerticalAlignment="Center"
							Visibility="{Binding PlaceListViewModel.IsVisitedAddPlaceTextVisible}"
							Grid.ColumnSpan="2"
						>
                            Додайте місце для перегляду
                        </ui:TextBlock>
					</Grid>

					<GridSplitter
						Grid.Row="1"
						Height="5"
						HorizontalAlignment="Stretch"
						VerticalAlignment="Center"
						Background="Transparent"
						Cursor="SizeNS"
						Margin="0,4,0,4"
					/>

					<Border
						Grid.Row="2"
						Padding="16"
						Margin="0,8,0,0"
						Visibility="{Binding PlaceListViewModel.IsSelectedPlaceExists}"
					>
						<TabControl>
							<TabItem>
								<TabItem.Header>
									<StackPanel Orientation="Horizontal">
										<ui:SymbolIcon Symbol="Info20" Margin="0,0,6,0" />
										<TextBlock Text="Деталі" VerticalAlignment="Center" />
									</StackPanel>
								</TabItem.Header>
								<Grid DataContext="{Binding PlaceListViewModel.DetailsTab}">
									<Grid.RowDefinitions>
										<RowDefinition Height="Auto" />
										<RowDefinition Height="*" />
									</Grid.RowDefinitions>
									<Grid Margin="0,0,0,12">
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="*" />
											<ColumnDefinition Width="Auto" />
											<ColumnDefinition Width="8" />
											<ColumnDefinition Width="Auto" />
										</Grid.ColumnDefinitions>
										<ui:TextBlock
											Grid.Column="0"
											Text="Деталі місця"
											FontSize="16"
											FontWeight="Bold"
											VerticalAlignment="Center"
										/>
										<ui:Button
											Grid.Column="1"
											Appearance="Caution"
											Icon="{ui:SymbolIcon Symbol=Edit20}"
											Command="{Binding ToggleEditCommand}"
										>
                                            Редагувати
                                        </ui:Button>
										<ui:Button
											Grid.Column="3"
											Appearance="Danger"
											Command="{Binding DeletePlaceCommand}"
											Icon="{ui:SymbolIcon Symbol=Delete20}"
										>
                                            Видалити обраний запис
                                        </ui:Button>
									</Grid>

									<ScrollViewer
										Grid.Row="1"
										VerticalScrollBarVisibility="Auto"
										CanContentScroll="True"
									>
										<StackPanel
											Margin="0,0,12,0"
											IsEnabled="{Binding IsEditing}"
										>
											<Grid Margin="0,0,0,8">
												<Grid.ColumnDefinitions>
													<ColumnDefinition Width="*" />
													<ColumnDefinition Width="12" />
													<ColumnDefinition Width="*" />
												</Grid.ColumnDefinitions>

												<StackPanel Grid.Column="0">
													<ui:TextBlock Text="Назва *" Margin="0,0,0,4" />
													<ui:TextBox Text="{Binding EditedName, UpdateSourceTrigger=PropertyChanged}" />
												</StackPanel>

												<StackPanel Grid.Column="2">
													<ui:TextBlock
														Text="Країна *"
														Margin="0,0,0,4"
													/>
													<ui:TextBox Text="{Binding EditedCountry, UpdateSourceTrigger=PropertyChanged}" />
												</StackPanel>
											</Grid>

											<ui:TextBlock Text="Опис *" Margin="0,0,0,4" />
											<ui:TextBox
												Text="{Binding EditedDescription, UpdateSourceTrigger=PropertyChanged}"
												AcceptsReturn="True"
												TextWrapping="Wrap"
												MinHeight="60"
												Margin="0,0,0,8"
											/>

											<ui:TextBlock
												Text="Дата відвідування"
												Margin="0,0,0,4"
											/>
											<DatePicker
												SelectedDate="{Binding EditedVisitDate}"
												Margin="0,0,0,8"
											/>

											<ui:TextBlock Text="Рейтинг" Margin="0,0,0,4" />
											<ui:RatingControl
												Value="{Binding EditedRating, Mode=TwoWay, TargetNullValue=0}"
												HalfStarEnabled="False"
												Margin="0,0,0,8"
											/>

											<StackPanel Orientation="Horizontal" Margin="0,0,0,8">
												<CheckBox IsChecked="{Binding EditedIsVisited}" />
												<TextBlock
													Text="Місто відвідане"
													VerticalAlignment="Center"
													Margin="8,0,0,0"
												/>
											</StackPanel>

											<StackPanel
												Visibility="{Binding IsEditHistoricalVisible}"
												Margin="0,0,0,8"
											>
												<ui:TextBlock
													Text="Рік побудови"
													Margin="0,0,0,4"
												/>
												<ui:TextBox Text="{Binding EditedHistoricalYearBuilt, Mode=TwoWay}" />

												<ui:TextBlock
													Text="Значимість (1-10)"
													Margin="0,8,0,4"
												/>
												<Slider
													TickPlacement="Both"
													Minimum="1"
													Maximum="10"
													IsSnapToTickEnabled="True"
													TickFrequency="1"
													Value="{Binding EditedHistoricalSignificance, Mode=TwoWay}"
												/>
											</StackPanel>

											<StackPanel
												Visibility="{Binding IsEditNaturalVisible}"
												Margin="0,0,0,8"
											>
												<ui:TextBlock
													Text="Рік утворення"
													Margin="0,0,0,4"
												/>
												<ui:TextBox Text="{Binding EditedNaturalYearFormed, Mode=TwoWay}" />
												<StackPanel
													Orientation="Horizontal"
													Margin="0,8,0,0"
												>
													<ui:TextBlock
														Text="Під захистом"
														VerticalAlignment="Center"
														Margin="0,0,8,0"
													/>
													<CheckBox IsChecked="{Binding EditedNaturalProtectedStatus, Mode=TwoWay}" />
												</StackPanel>
											</StackPanel>

											<StackPanel
												Orientation="Horizontal"
												Margin="0,8,0,0"
												IsEnabled="{Binding IsEditing}"
											>
												<ui:Button
													Appearance="Primary"
													Command="{Binding Path=SaveEditCommand}"
												>
                                                    Зберегти
                                                </ui:Button>
												<ui:Button
													Appearance="Secondary"
													Command="{Binding Path=CancelEditCommand}"
													Margin="8,0,0,0"
												>
                                                    Скасувати
                                                </ui:Button>
											</StackPanel>
										</StackPanel>
									</ScrollViewer>
								</Grid>
							</TabItem>

							<TabItem>
								<TabItem.Header>
									<StackPanel Orientation="Horizontal">
										<ui:SymbolIcon Symbol="WeatherMoon20" Margin="0,0,6,0" />
										<TextBlock Text="Погода" VerticalAlignment="Center" />
									</StackPanel>
								</TabItem.Header>
								<StackPanel
									Orientation="Horizontal"
									HorizontalAlignment="Left"
									VerticalAlignment="Center"
									Margin="0,8,0,0"
									DataContext="{Binding PlaceListViewModel.WeatherTab}"
								>
									<TextBlock
										Text="{Binding WeatherSummary}"
										Margin="0,0,8,0"
										VerticalAlignment="Center"
									/>
									<Image
										Source="{Binding WeatherIconPath, TargetNullValue={x:Null}}"
										Width="40"
										Height="40"
									/>
								</StackPanel>
							</TabItem>
							<TabItem>
								<TabItem.Header>
									<StackPanel Orientation="Horizontal">
										<ui:SymbolIcon Symbol="Chat20" Margin="0,0,6,0" />
										<TextBlock Text="Відгуки" VerticalAlignment="Center" />
									</StackPanel>
								</TabItem.Header>
								<StackPanel
									Margin="0,12,0,0"
									DataContext="{Binding PlaceListViewModel.ReviewsTab}"
								>
									<ScrollViewer
										VerticalScrollBarVisibility="Auto"
										MaxHeight="200"
									>
										<ItemsControl ItemsSource="{Binding Reviews}">
											<ItemsControl.ItemTemplate>
												<DataTemplate>
													<Border
														Padding="8"
														Margin="0,0,0,6"
														Background="#1AFFFFFF"
														CornerRadius="6"
													>
														<DockPanel LastChildFill="True">
															<StackPanel
																Orientation="Horizontal"
																HorizontalAlignment="Right"
																DockPanel.Dock="Right"
															>
																<TextBlock
																	Text="{Binding Value, StringFormat='{}{0:0.0}'}"
																	Margin="0,0,8,0"
																	VerticalAlignment="Center"
																/>
																<Button
																	Padding="8,4"
																	Margin="6,0,0,0"
																	Command="{Binding DataContext.RemoveReviewCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
																	CommandParameter="{Binding Key}"
																>
                                                                    Видалити
                                                                </Button>
															</StackPanel>
															<TextBlock
																Text="{Binding Key}"
																TextWrapping="Wrap"
																VerticalAlignment="Center"
																Margin="0,0,10,0"
															/>
														</DockPanel>
													</Border>
												</DataTemplate>
											</ItemsControl.ItemTemplate>
										</ItemsControl>
									</ScrollViewer>

									<StackPanel Orientation="Vertical" Margin="0,8,0,0">
										<ui:TextBox
											Text="{Binding NewReviewText, UpdateSourceTrigger=PropertyChanged}"
											PlaceholderText="Напишіть відгук..."
											AcceptsReturn="True"
											MinHeight="60"
										/>
										<StackPanel Orientation="Horizontal" Margin="0,8,0,0">
											<ui:RatingControl
												Value="{Binding NewReviewRating, Mode=TwoWay, TargetNullValue=0}"
												HalfStarEnabled="False"
											/>
											<ui:Button
												Appearance="Success"
												Margin="8,0,0,0"
												Command="{Binding AddReviewCommand}"
											>
                                                Додати відгук
                                            </ui:Button>
										</StackPanel>
									</StackPanel>
								</StackPanel>
							</TabItem>
						</TabControl>
					</Border>
				</Grid>
			</TabItem>

			<TabItem
				Visibility="{Binding PlaceListViewModel.IsAnyPlaces}"
				Height="36"
				VerticalAlignment="Top"
			>
				<TabItem.Header>
					<StackPanel Orientation="Horizontal">
						<ui:SymbolIcon Symbol="SlideTextMultiple20" Margin="0,0,6,0" />
						<TextBlock Text="Статистика" VerticalAlignment="Center" />
					</StackPanel>
				</TabItem.Header>

				<StackPanel
					Orientation="Vertical"
					DataContext="{Binding PlaceListViewModel.StatisticTab}"
					Margin="16"
				>
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="2*" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
						</Grid.ColumnDefinitions>
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
						</Grid.RowDefinitions>

						<TextBlock
							Text="Всього місць:"
							FontSize="14"
							Margin="0,0,0,4"
							Grid.Column="0"
							Grid.Row="0"
						/>
						<TextBlock
							Text="{Binding AllPlacesCount}"
							FontSize="16"
							FontWeight="Bold"
							Margin="0,0,0,12"
							Grid.Column="2"
							Grid.Row="0"
						/>

						<TextBlock
							Text="Звичайних місць:"
							FontSize="14"
							Margin="0,0,0,4"
							Grid.Column="0"
							Grid.Row="1"
						/>
						<TextBlock
							Text="{Binding NormalPlacesCount}"
							FontSize="16"
							FontWeight="Bold"
							Margin="0,0,0,12"
							Grid.Column="2"
							Grid.Row="1"
						/>

						<TextBlock
							Text="Звичайних місць:"
							FontSize="14"
							Margin="0,0,0,4"
							Grid.Column="0"
							Grid.Row="2"
						/>
						<TextBlock
							Text="{Binding HistoricalPlacesCount}"
							FontSize="16"
							FontWeight="Bold"
							Margin="0,0,0,12"
							Grid.Column="2"
							Grid.Row="2"
						/>

						<TextBlock
							Text="Природних місць:"
							FontSize="14"
							Margin="0,0,0,4"
							Grid.Column="0"
							Grid.Row="3"
						/>
						<TextBlock
							Text="{Binding NaturalPlacesCount}"
							FontSize="16"
							FontWeight="Bold"
							Margin="0,0,0,12"
							Grid.Column="2"
							Grid.Row="3"
						/>

						<TextBlock
							Text="Середній рейтинг місць:"
							FontSize="14"
							Margin="0,0,0,4"
							Grid.Column="0"
							Grid.Row="4"
						/>
						<TextBlock
							Text="{Binding AverageRating, StringFormat='{}{0:F1}'}"
							FontSize="16"
							FontWeight="Bold"
							Margin="0,0,0,12"
							Grid.Column="2"
							Grid.Row="4"
						/>

						<TextBlock
							Text="Всього відвіданих місць:"
							FontSize="14"
							Margin="0,0,0,4"
							Grid.Column="0"
							Grid.Row="5"
						/>
						<TextBlock
							Text="{Binding VisitedCount}"
							FontSize="16"
							FontWeight="Bold"
							Margin="0,0,0,12"
							Grid.Column="2"
							Grid.Row="5"
						/>

						<TextBlock
							Text="Остання дата відвідування:"
							FontSize="14"
							Margin="0,0,0,4"
							Grid.Column="0"
							Grid.Row="6"
						/>
						<TextBlock
							Text="{Binding MostRecentVisitDate, TargetNullValue='Немає даних', StringFormat='{}{0:dd.MM.yyyy}'}"
							FontSize="16"
							Margin="0,0,0,12"
							Grid.Column="2"
							Grid.Row="6"
						/>

						<TextBlock
							Text="Відвідано цього року:"
							FontSize="14"
							Margin="0,0,0,4"
							Grid.Column="0"
							Grid.Row="7"
						/>
						<TextBlock
							Text="{Binding VisitedPerCurrentYear}"
							FontSize="16"
							FontWeight="Bold"
							Margin="0,0,0,12"
							Grid.Column="2"
							Grid.Row="7"
						/>

						<TextBlock
							Text="Найвідвідуваніша країна:"
							FontSize="14"
							Margin="0,0,0,4"
							Grid.Column="0"
							Grid.Row="8"
						/>
						<TextBlock
							Text="{Binding MostVisitedCountry}"
							FontSize="16"
							FontWeight="Bold"
							Margin="0,0,0,12"
							Grid.Column="2"
							Grid.Row="8"
						/>
					</Grid>
				</StackPanel>
			</TabItem>
		</TabControl>
	</Grid>
</UserControl>

<UserControl x:Class="OOPWPFProject.Views.MainContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl>
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Location20" Margin="0,0,6,0"/>
                        <TextBlock Text="Відвідані місця" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <ui:DataGrid x:Name="PlacesDataGrid"
                                     ItemsSource="{Binding PlaceListViewModel.Places}"
                                     SelectedItem="{Binding PlaceListViewModel.SelectedPlace}"
                                     Visibility="{Binding PlaceListViewModel.IsPlaceExists}"
                                     AutoGenerateColumns="False"
                                     IsReadOnly="True"
                                     SelectionMode="Single"
                                     HeadersVisibility="Column"
                                     Margin="0,0,0,16">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Місто" Width="*" SortMemberPath="NameOfPlace">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon x:Name="StarIcon"
                                                               Symbol="Star20"
                                                               Filled="True"
                                                               Foreground="#FFD700"
                                                               Margin="0,0,6,0"
                                                               Visibility="Collapsed" />
                                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                            </StackPanel>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsHighlyRated}" Value="True">
                                                    <Setter TargetName="StarIcon" Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Країна" Binding="{Binding Country}" Width="*"/>
                                <DataGridTextColumn Header="Опис" Binding="{Binding Description, Mode=OneWay}" Width="1.5*"/>
                                <DataGridTextColumn Header="Дата" Binding="{Binding Date, Mode=OneWay, StringFormat='{}{0:dd/MM/yyyy}'}" Width="*"/>
                                <DataGridTextColumn Header="Рейтинг" Binding="{Binding Rating, Mode=OneWay}" Width="*"/>
                            </DataGrid.Columns>
                        </ui:DataGrid>

                        <ui:TextBlock FontSize="48"
                                      FontFamily="Lucida Console"
                                      FontWeight="Light"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Visibility="{Binding PlaceListViewModel.IsAddPlaceTextVisible}">
                            Додайте місце для перегляду
                        </ui:TextBlock>
                    </Grid>

                    <Border Grid.Row="1"
                            Padding="16"
                            Margin="0,8,0,0"
                            Visibility="{Binding PlaceListViewModel.IsSelectedPlaceExists}">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ui:TextBlock Grid.Column="0"
                                              Text="Деталі місця"
                                              FontSize="16"
                                              FontWeight="Bold"
                                              VerticalAlignment="Center" />
                                <ui:Button Grid.Column="1"
                                           Appearance="Danger"
                                           Command="{Binding PlaceListViewModel.DeletePlaceCommand}"
                                           Icon="{ui:SymbolIcon Symbol=Delete20}">
                                    Видалити обраний запис
                                </ui:Button>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="2" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding PlaceListViewModel.SelectedPlaceDetails, Mode=OneWay}"
                                           TextWrapping="Wrap"
                                           LineHeight="1.5" />

                                <StackPanel Grid.Column="2" Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding PlaceListViewModel.WeatherSummary}" Margin="0,0,8,0" VerticalAlignment="Center" />
                                        <Image Source="{Binding PlaceListViewModel.WeatherIconPath, TargetNullValue={x:Null}}" Width="40" Height="40" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                            <StackPanel Margin="0,12,0,0">
                                <ui:TextBlock Text="Відгуки" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6" />
                                <ItemsControl ItemsSource="{Binding PlaceListViewModel.SelectedPlace.Reviews}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="8" Margin="0,0,0,6" Background="#1AFFFFFF" CornerRadius="6">
                                                <DockPanel LastChildFill="True">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                                                        <TextBlock Text="{Binding Value, StringFormat='{}{0:0.0}'}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                        <ui:Button Appearance="Danger"
                                                                   Padding="8,4" Margin="6,0,0,0"
                                                                   Command="{Binding DataContext.PlaceListViewModel.RemoveReviewCommand}"
                                                                   CommandParameter="{Binding Key}">
                                                            Видалити
                                                        </ui:Button>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Key}" TextWrapping="Wrap" VerticalAlignment="Center" Margin="0,0,10,0" />
                                                </DockPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <StackPanel Orientation="Vertical" Margin="0,8,0,0">
                                    <ui:TextBox Text="{Binding PlaceListViewModel.NewReviewText, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Напишіть відгук..." AcceptsReturn="True" MinHeight="60" />
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <ui:RatingControl Value="{Binding PlaceListViewModel.NewReviewRating, Mode=TwoWay, TargetNullValue=0}" HalfStarEnabled="False" />
                                        <ui:Button Appearance="Success" Margin="8,0,0,0" Command="{Binding PlaceListViewModel.AddReviewCommand}">
                                            Додати відгук
                                        </ui:Button>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Info20" Margin="0,0,6,0"/>
                        <TextBlock Text="Заплановані місця" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <ui:DataGrid x:Name="PlannedPlacesDataGrid"
                                     ItemsSource="{Binding PlaceListViewModel.Places}"
                                     SelectedItem="{Binding PlaceListViewModel.SelectedPlace}"
                                     Visibility="{Binding PlaceListViewModel.IsPlaceExists}"
                                     AutoGenerateColumns="False"
                                     IsReadOnly="True"
                                     SelectionMode="Single"
                                     HeadersVisibility="Column"
                                     Margin="0,0,0,16">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Місто" Width="*" SortMemberPath="NameOfPlace">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon x:Name="StarIcon"
                                                               Symbol="Star20"
                                                               Filled="True"
                                                               Foreground="#FFD700"
                                                               Margin="0,0,6,0"
                                                               Visibility="Collapsed" />
                                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                            </StackPanel>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsHighlyRated}" Value="True">
                                                    <Setter TargetName="StarIcon" Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Країна" Binding="{Binding Country}" Width="*"/>
                                <DataGridTextColumn Header="Опис" Binding="{Binding Description, Mode=OneWay}" Width="1.5*"/>
                                <DataGridTextColumn Header="Дата" Binding="{Binding Date, Mode=OneWay, StringFormat='{}{0:dd/MM/yyyy}'}" Width="*"/>
                                <DataGridTextColumn Header="Рейтинг" Binding="{Binding Rating, Mode=OneWay}" Width="*"/>
                            </DataGrid.Columns>
                        </ui:DataGrid>

                        <ui:TextBlock FontSize="48"
                                      FontFamily="Lucida Console"
                                      FontWeight="Light"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Visibility="{Binding PlaceListViewModel.IsAddPlaceTextVisible}">
                            Додайте місце для перегляду
                        </ui:TextBlock>
                    </Grid>

                    <Border Grid.Row="1"
                            Padding="16"
                            Margin="0,8,0,0"
                            Visibility="{Binding PlaceListViewModel.IsSelectedPlaceExists}">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ui:TextBlock Grid.Column="0"
                                              Text="Деталі місця"
                                              FontSize="16"
                                              FontWeight="Bold"
                                              VerticalAlignment="Center" />
                                <ui:Button Grid.Column="1"
                                           Appearance="Danger"
                                           Command="{Binding PlaceListViewModel.DeletePlaceCommand}"
                                           Icon="{ui:SymbolIcon Symbol=Delete20}">
                                    Видалити обраний запис
                                </ui:Button>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="2" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding PlaceListViewModel.SelectedPlaceDetails, Mode=OneWay}"
                                           TextWrapping="Wrap"
                                           LineHeight="1.5" />

                                <StackPanel Grid.Column="2" Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding PlaceListViewModel.WeatherSummary}" Margin="0,0,8,0" VerticalAlignment="Center" />
                                        <Image Source="{Binding PlaceListViewModel.WeatherIconPath, TargetNullValue={x:Null}}" Width="40" Height="40" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                            <StackPanel Margin="0,12,0,0">
                                <ui:TextBlock Text="Відгуки" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6" />
                                <ItemsControl ItemsSource="{Binding PlaceListViewModel.SelectedPlace.Reviews}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="8" Margin="0,0,0,6" Background="#1AFFFFFF" CornerRadius="6">
                                                <DockPanel LastChildFill="True">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                                                        <TextBlock Text="{Binding Value, StringFormat='{}{0:0.0}'}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                        <ui:Button Appearance="Danger"
                                                                   Padding="8,4" Margin="6,0,0,0"
                                                                   Command="{Binding DataContext.PlaceListViewModel.RemoveReviewCommand}"
                                                                   CommandParameter="{Binding Key}">
                                                            Видалити
                                                        </ui:Button>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Key}" TextWrapping="Wrap" VerticalAlignment="Center" Margin="0,0,10,0" />
                                                </DockPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <StackPanel Orientation="Vertical" Margin="0,8,0,0">
                                    <ui:TextBox Text="{Binding PlaceListViewModel.NewReviewText, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Напишіть відгук..." AcceptsReturn="True" MinHeight="60" />
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <ui:RatingControl Value="{Binding PlaceListViewModel.NewReviewRating, Mode=TwoWay, TargetNullValue=0}" HalfStarEnabled="False" />
                                        <ui:Button Appearance="Success" Margin="8,0,0,0" Command="{Binding PlaceListViewModel.AddReviewCommand}">
                                            Додати відгук
                                        </ui:Button>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>

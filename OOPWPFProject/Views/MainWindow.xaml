<ui:FluentWindow
	x:Class="OOPWPFProject.MainWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
	xmlns:local="clr-namespace:OOPWPFProject"
	xmlns:viewmodels="clr-namespace:OOPWPFProject.ViewModels"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:views="clr-namespace:OOPWPFProject.Views"
	Title="Mango"
	Height="700"
	Width="1600"
	MinHeight="650"
	MinWidth="1600"
	WindowStartupLocation="CenterScreen"
	FontFamily="Cascadia Code"
	FontWeight="Normal"
	Icon="/Resources/Mango.ico"
	ExtendsContentIntoTitleBar="True"
	Background="#FF202020"
	Foreground="#FFF5F5F5"
>
	<DockPanel>
		<ui:TitleBar DockPanel.Dock="Top" Title="Mango" FontWeight="Bold" />
		<Grid>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="*" />
			</Grid.ColumnDefinitions>

			<views:LeftPanel Grid.Column="0" />
			<views:MainContent Grid.Column="1" />
		</Grid>
	</DockPanel>
</ui:FluentWindow>

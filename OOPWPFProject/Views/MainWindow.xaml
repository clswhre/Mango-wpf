<ui:FluentWindow x:Class="OOPWPFProject.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:OOPWPFProject" xmlns:viewmodels="clr-namespace:OOPWPFProject.ViewModels" xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        Title="Mango" 
        Height="650" Width="1600" 
        MinHeight="650" MinWidth="1600" 
        WindowStartupLocation="CenterScreen"
        FontFamily="Cascadia Code" 
        FontWeight="Normal"
        Icon="/Resources/Mango.ico"
        ExtendsContentIntoTitleBar="True"
        Background="{DynamicResource ApplicationBackgroundBrush}"
        Foreground="{DynamicResource TextFillColorPrimaryBrush}">


    <DockPanel>
        <ui:TitleBar DockPanel.Dock="Top" Title="Mango" FontWeight="Bold"/>

        <Grid>
        <!-- Місце для лівої панельки і списку місць -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- #region "ЛІВА ПАНЕЛЬ" -->

        <ScrollViewer 
            Grid.Column="0" 
            VerticalScrollBarVisibility="Auto" 
            HorizontalScrollBarVisibility="Disabled" 
            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" 
            BorderThickness="0,0,1,0">

            <!-- #region "ТЕКСТБОКСИ: місто, країна, опис" -->
            <StackPanel Margin="20" HorizontalAlignment="Stretch">

                <ui:TextBlock Text="Назва міста *" Margin="0,0,0,4" />
                <ui:TextBox x:Name="CityTextBox" 
                            Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}" 
                            PlaceholderText="Львів" 
                            Margin="0,0,0,16"/>

                <ui:TextBlock Text="Країна *" Margin="0,0,0,4" />
                <ui:TextBox x:Name="CountryTextBox" 
                            Text="{Binding NewCountry, UpdateSourceTrigger=PropertyChanged}" 
                            PlaceholderText="Україна" 
                            Margin="0,0,0,16" 
                            AutomationProperties.IsRequiredForForm="True"/>

                <ui:TextBlock Text="Опис *" Margin="0,0,0,4" />
                <ui:TextBox x:Name="DescriptionTextBox" 
                    Text="{Binding NewDescription, UpdateSourceTrigger=PropertyChanged}" 
                    PlaceholderText="Це місто кави, місто тисячі левів,&#x0a;місто джазу, дощу,шоколаду, терас&#x0a;і пристрасного танго." 
                    TextWrapping="Wrap"
                    AcceptsReturn="True"
                    MinHeight="70" 
                    Margin="0,0,0,16"/>

                <ui:TextBlock Text="Примітки" Margin="0,0,0,4" />
                <ui:TextBox x:Name="NotesTextBox" 
                        Text="{Binding NewNotes, UpdateSourceTrigger=PropertyChanged}" 
                        PlaceholderText="Додаткова інформація..." 
                        Margin="0,0,0,16"/>
                <!--#endregion-->
                
                <!-- #region "Колонки: Дата + Рейтинг" -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Дата -->
                    <StackPanel Grid.Column="0">
                        <ui:TextBlock Text="Дата відвідування" Margin="0,0,0,4"/>
                        <DatePicker x:Name="DatePickerBox" SelectedDate="{Binding NewVisitDate}" HorizontalAlignment="Stretch"/>
                    </StackPanel>

                    <!-- Рейтинг -->
                    <StackPanel Grid.Column="2">
                        <ui:TextBlock Text="Рейтинг" Margin="0,0,0,4"/>
                        <ui:RatingControl x:Name="Rating" Value="{Binding NewRating, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HalfStarEnabled="False"/>
                    </StackPanel>

                </Grid>
                <!--#endregion-->

                <!--#region "Тип місця + поля що залежать від вибору"-->
            <StackPanel >
                <ui:TextBlock>
                    Тип місця
                </ui:TextBlock>
                <ComboBox
                    Margin="0,0,0,20"
                    ItemsSource="{Binding PlaceTypes}"
                    SelectedItem="{Binding SelectedPlaceType, Mode=TwoWay}" 
                    />
            </StackPanel>

            <!-- Поля для Historical -->
                <StackPanel Visibility="{Binding IsHistoricalSelected}" Margin="0,0,0,12">
                <ui:TextBlock Text="Рік побудови" Margin="0,0,0,4" />
                <DatePicker SelectedDate="{Binding HistoricalYearBuiltDate, Mode=TwoWay}" />

                <ui:TextBlock Text="Значимість (1-10)" Margin="0,8,0,4" />

                <Slider TickPlacement="Both"
                    Minimum="1" Maximum="10"
                    IsSnapToTickEnabled="True"
                    TickFrequency="1"
                    Value="{Binding HistoricalSignificance, Mode=TwoWay}"
                />
            </StackPanel>

            <!-- Поля для Natural -->
                <StackPanel Visibility="{Binding IsNaturalSelected}" Margin="0,0,0,12">
                <ui:TextBlock Text="Рік утворення" Margin="0,0,0,4" />
                <DatePicker SelectedDate="{Binding NaturalYearBuiltDate, Mode=TwoWay}" />
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <ui:TextBlock Text="Під захистом" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <CheckBox IsChecked="{Binding NaturalProtectedStatus, Mode=TwoWay}" />
                </StackPanel>
            </StackPanel>
            <!--#endregion-->
                
                <!-- #region 2 Колонки: "Додати місце" + "Очистити форму" -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- КНОПКА "Додати місце" -->
                    <ui:Button 
                        Grid.Column="0" 
                        HorizontalAlignment="Stretch" 
                        Appearance="Success" 
                        Icon="{ui:SymbolIcon Symbol=Add20}"
                        Command="{Binding AddPlaceCommand}">
                        Додати запис
                    </ui:Button>

                    <!-- КНОПКА "Очистити форму" -->
                    <ui:Button 
                        Grid.Column="2"
                        Appearance="Secondary" 
                        HorizontalAlignment="Stretch" 
                        Icon="{ui:SymbolIcon Symbol=Broom20}"
                        Command="{Binding ClearFormCommand}"
                    />
                </Grid>
                <!-- Примітка: Обов'язкові поля -->
                <ui:TextBlock Opacity="0.6">
                    * - обов'язкові для заповнення поля
                </ui:TextBlock>

                <Expander Header="Додаткові інструменти" IsExpanded="False" Margin="0,8,0,0">
                    
                    <StackPanel>
                            <ui:TextBlock HorizontalAlignment="Center" VerticalAlignment="Center">
                                Високооцінені місця
                            </ui:TextBlock>
                            <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="5" />
                                <ColumnDefinition Width="2*" />
                            </Grid.ColumnDefinitions>

                            <ui:Button
                                Grid.Column="0" 
                                Margin="0,8,0,0"
                                Appearance="Primary"
                                Icon="{ui:SymbolIcon Symbol=Save20}"
                                Command="{Binding HighlyRatedSaveCommand}">
                                Зберегти 
                            </ui:Button>

                            <ui:Button
                                Grid.Column="2" 
                                Margin="0,8,0,0"
                                Appearance="Secondary"
                                Icon="{ui:SymbolIcon Symbol=FolderOpen20}"
                                Command="{Binding HighlyRatedLoadCommand}">
                                Завантажити
                            </ui:Button>
                        </Grid>

                        <!-- #region "ІНДЕКСАТОР" -->
                        <Expander Header="Пошук за індексом" IsExpanded="False" Margin="0,8,0,0">
                            <StackPanel>
                                <ui:TextBlock Text="Введіть індекс" Margin="0,0,0,4" />
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <ui:NumberBox 
                                        Grid.Column="0"
                                        Value="{Binding IndexToShow, UpdateSourceTrigger=PropertyChanged}"
                                        Minimum="0"
                                        HorizontalAlignment="Stretch" />

                                    <ui:Button 
                                        Grid.Column="2"
                                        Appearance="Secondary"
                                        Icon="{ui:SymbolIcon Symbol=Search20}"
                                        Command="{Binding ShowByIndexCommand}"
                                        Padding="12,8" />
                                </Grid>

                                <ui:TextBlock Text="Результат:" Margin="0,0,0,4" Opacity="0.7" FontSize="12" />
                                <TextBlock 
                                    Text="{Binding PlaceAtIndexDisplay}"
                                    TextWrapping="Wrap"
                                    MinHeight="40"
                                    Padding="8" />
                            </StackPanel>
                        </Expander>
                        <!--#endregion-->

                        <Expander Header="Перевантажені оператори" IsExpanded="False" Margin="0,8,0,0">
                                <StackPanel>
                                    <TextBlock> 1 об'єкт</TextBlock>
                                <ComboBox ItemsSource="{Binding Places}" DisplayMemberPath="Name" SelectedItem="{Binding SelectedObject1}" Margin="0,0,0,5" />

                                <TextBlock> 2 об'єкт</TextBlock>
                                <ComboBox ItemsSource="{Binding Places}" DisplayMemberPath="Name" SelectedItem="{Binding SelectedObject2}" Margin="0,0,0,5" />

                                <TextBlock> Операція</TextBlock>
                                <ComboBox ItemsSource="{Binding Operators}" SelectedItem="{Binding SelectedOperator}" Margin="0,0,0,5" />

                                <ui:Button Appearance="Primary" Command="{Binding overridedOperatorActon}" HorizontalAlignment="Stretch" Margin="0,5,0,5">
                                    Виконати операцію
                                </ui:Button>

                                <TextBlock Text="Результат:" Margin="0,5,0,2" Opacity="0.7" FontSize="12" />
                                <TextBlock Text="{Binding OperatorResult}" TextWrapping="Wrap" MinHeight="40" Background="{DynamicResource ControlFillColorDefaultBrush}" Padding="8" />
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </Expander>
                </StackPanel>
        </ScrollViewer>
        <!--#endregion-->

        <!-- #region "СПИСОК МІСЦЬ + деталі" -->
        <Grid Grid.Column="1" Margin="10" Visibility="{Binding IsPlaceExists}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  #region "Датагрід " -->
            <ui:DataGrid x:Name="PlacesDataGrid"  
                Grid.Row="0"
                ItemsSource="{Binding Places}" 
                SelectedItem="{Binding SelectedPlace}"
                         Visibility="{Binding IsPlaceExists}"
                AutoGenerateColumns="False" 
                IsReadOnly="True"
                SelectionMode="Single"
                HeadersVisibility="Column"
                Margin="0,0,0,16">

                <!-- #region "КОЛОНКИ ДАТАГРІДА" -->
                <!-- Назва місця + зірка при рейтингу > 4 -->
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Місто" Width="*" SortMemberPath="NameOfPlace">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon x:Name="StarIcon" 
                                           Symbol="Star20"
                                           Filled="True"
                                           Foreground="#FFD700" 
                                           Margin="0,0,6,0" 
                                           Visibility="Collapsed" />
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                </StackPanel>

                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsHighlyRated}" Value="True">
                                        <Setter TargetName="StarIcon" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>

                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    


                    <!-- КРАЇНА / ОПИС / РЕЙТИНГ / ПРИМІТКИ -->
                    <DataGridTextColumn Header="Країна" Binding="{Binding Country}" Width="*"/>
                    <DataGridTextColumn Header="Опис" Binding="{Binding Description, Mode=OneWay}" Width="1.5*"/>
                    <DataGridTextColumn Header="Дата" Binding="{Binding Date, Mode=OneWay, StringFormat='{}{0:dd/MM/yyyy}'}" Width="*"/>
                    <DataGridTextColumn Header="Рейтинг" Binding="{Binding Rating, Mode=OneWay}" Width="*"/>
                    <DataGridTextColumn Header="Примітки" Binding="{Binding Notes, Mode=TwoWay}" Width="*"/>
                    <DataGridTextColumn Header="Підсумок подорожі" Binding="{Binding TravelSummary, Mode=OneTime}" Width="*"/>
                </DataGrid.Columns>
            </ui:DataGrid>
            <!--#endregion-->
            <!--#endregion-->
            <!-- #region "ПАНЕЛЬ ДЕТАЛЕЙ" -->
           
            <!-- татишопесня 
            сюди підключить мб якусь апішку 
            + парсить картинку з вікіпедії на крусову-->
            
            <Border 
                Grid.Row="1"
                Background="{DynamicResource ControlAltFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="16"
                Margin="0,8,0,0"
                Visibility="{Binding IsSelectedPlaceExists}">

                <StackPanel Visibility="{Binding IsSelectedPlaceExists}">
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <ui:TextBlock 
                                Grid.Column="0"
                                Text="Деталі місця" 
                                FontSize="16" 
                                FontWeight="Bold"
                                VerticalAlignment="Center"
                                Visibility="{Binding IsSelectedPlaceExists}"
                            />

                            <!-- #region "КНОПКА "Видалити запис"" -->
                            <ui:Button 
                                Grid.Column="1"
                                Appearance="Danger" 
                                Command="{Binding DeletePlaceCommand}"
                                Visibility="{Binding IsSelectedPlaceExists}"
                                Icon="{ui:SymbolIcon Symbol=Delete20}">
                                Видалити обраний запис
                            </ui:Button>
                            <!--#endregion-->
                        </Grid>
                            <TextBlock 
                            Text="{Binding SelectedPlaceDetails, Mode=OneWay}"
                            TextWrapping="Wrap"
                            LineHeight="1.5" 
                                Visibility="{Binding IsSelectedPlaceExists}"/>
                            <!-- Reviews  -->
                        <StackPanel Margin="0,12,0,0"
                                    Visibility="{Binding IsSelectedPlaceExists}">
                            <ui:TextBlock Text="Відгуки" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6"/>

                            <ItemsControl ItemsSource="{Binding SelectedPlace.Reviews}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="8" Margin="0,0,0,6" Background="{DynamicResource ControlFillColorPrimaryBrush}" CornerRadius="6">
                                            <DockPanel LastChildFill="True">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                                                    <TextBlock Text="{Binding Value, StringFormat='{}{0:0.0}'}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                    <ui:Button Appearance="Danger" Content="Видалити" Padding="8,4" Margin="6,0,0,0"
                                                                   Command="{Binding DataContext.RemoveReviewCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                   CommandParameter="{Binding Key}"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Key}" TextWrapping="Wrap" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- введення review -->
                            <StackPanel Orientation="Vertical" Margin="0,8,0,0">
                                <ui:TextBox Text="{Binding NewReviewText, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Напишіть відгук..." AcceptsReturn="True" MinHeight="60"/>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <ui:RatingControl Value="{Binding NewReviewRating, Mode=TwoWay, TargetNullValue=0}" HalfStarEnabled="False"/>
                                    <ui:Button Content="Додати відгук" Appearance="Success" Margin="8,0,0,0" Command="{Binding AddReviewCommand}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
            </Border>
            <!--#endregion-->
        </Grid>
        <!--#endregion-->
        </Grid>
    </DockPanel>
</ui:FluentWindow>

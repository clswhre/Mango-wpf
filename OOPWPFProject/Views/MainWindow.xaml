<ui:FluentWindow
    x:Class="OOPWPFProject.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:local="clr-namespace:OOPWPFProject"
    xmlns:viewmodels="clr-namespace:OOPWPFProject.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:views="clr-namespace:OOPWPFProject.Views"
    Title="Mango"
    Height="700"
    Width="1600"
    MinHeight="650"
    MinWidth="1600"
    WindowStartupLocation="CenterScreen"
    FontFamily="Cascadia Code"
    FontWeight="Normal"
    Icon="/Resources/Mango.ico"
    ExtendsContentIntoTitleBar="True"
>
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <DockPanel>
        <ui:TitleBar DockPanel.Dock="Top" Title="Mango" FontWeight="Bold" />

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <views:LeftPanel Grid.Column="0" />

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>

                    <RowDefinition Height="3*" />

                    <RowDefinition>
                        <RowDefinition.Style>
                            <Style TargetType="RowDefinition">
                                <Setter Property="Height" Value="5" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding MainContentViewModel.IsSelectedPlaceExistsAndNotStatisticTab}" Value="False">
                                        <Setter Property="Height" Value="0" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </RowDefinition.Style>
                    </RowDefinition>

                    <RowDefinition>
                        <RowDefinition.Style>
                            <Style TargetType="RowDefinition">
                                <Setter Property="Height" Value="2*" />
                                <Setter Property="MinHeight" Value="250" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding MainContentViewModel.IsSelectedPlaceExistsAndNotStatisticTab}" Value="False">
                                        <Setter Property="Height" Value="0" />
                                        <Setter Property="MinHeight" Value="0" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </RowDefinition.Style>
                    </RowDefinition>

                </Grid.RowDefinitions>

                <views:MainContent Grid.Row="0" DataContext="{Binding}" />

                <GridSplitter
                    Grid.Row="1"
                    Height="5"
                    HorizontalAlignment="Stretch"
                    ResizeDirection="Rows"
                    Visibility="{Binding MainContentViewModel.IsSelectedPlaceExistsAndNotStatisticTab, Converter={StaticResource BoolToVis}}"
                />

                <views:PlaceDetailsControl
                    Grid.Row="2"
                    DataContext="{Binding}"
                    Visibility="{Binding MainContentViewModel.IsSelectedPlaceExistsAndNotStatisticTab, Converter={StaticResource BoolToVis}}"
                />
            </Grid>

        </Grid>
    </DockPanel>
</ui:FluentWindow>
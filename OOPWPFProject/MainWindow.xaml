<Window x:Class="OOPWPFProject.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Mango" Height="450" Width="800" MinHeight="400" MinWidth="400" WindowStartupLocation="CenterScreen"
        FontFamily="Cascadia Mono" FontWeight="Regular"
        Background="{DynamicResource ApplicationBackgroundBrush}"
        Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">

        <StackPanel Margin="20" MaxWidth="600" HorizontalAlignment="Stretch">

            <ui:TextBlock Text="Назва міста" Margin="0,0,0,4" />
            <ui:TextBox x:Name="CityTextBox" PlaceholderText="Житомир"  Margin="0,0,0,16"/>

            <ui:TextBlock Text="Країна" Margin="0,0,0,4" />
            <ui:TextBox x:Name="CountryTextBox" PlaceholderText="Україна" Margin="0,0,0,16" AutomationProperties.IsRequiredForForm="True"/>
            
            <ui:TextBlock Text="Опис" Margin="0,0,0,4" />
            <ui:TextBox x:Name="DescriptionTextBox" PlaceholderText="обласний центр України, що розкинувся на мальовничих берегах ріки ..." 
                        TextWrapping="Wrap" MinHeight="60" Margin="0,0,0,16"/>

            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <ui:TextBlock Text="Дата відвідування" Margin="0,0,0,4"/>
                    <DatePicker x:Name="DatePickerBox" DisplayDate="01.01.26" HorizontalAlignment="Stretch"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <ui:TextBlock Text="Рейтинг" Margin="0,0,0,4"/>
                    <ui:RatingControl x:Name="Rating" HalfStarEnabled="False"/>
                </StackPanel>
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <ui:Button Grid.Column="0" HorizontalAlignment="Stretch" Click="AddPlacePressed">
                    Додати запис
                </ui:Button>
                <ui:Button Grid.Column="2" HorizontalAlignment="Stretch" Click="ClearFormPressed">
                    Очистити форму
                </ui:Button>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</Window>
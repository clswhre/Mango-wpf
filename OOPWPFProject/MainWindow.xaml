<Window x:Class="OOPWPFProject.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:OOPWPFProject" xmlns:viewmodels="clr-namespace:OOPWPFProject.ViewModels" xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:converters="clr-namespace:OOPWPFProject.Converters"
        Title="Mango" 
        Height="650" 
        Width="1600" 
        MinHeight="650" 
        MinWidth="1600" 
        WindowStartupLocation="CenterScreen"
        FontFamily="Cascadia Code" 
        FontWeight="Regular"
        Background="{DynamicResource ApplicationBackgroundBrush}"
        Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <Window.Resources>
        <converters:PlaceTypeToVisibilityConverter x:Key="PlaceTypeToVisibility" />
    </Window.Resources>

    <Grid>
        <!-- Місце для лівої панельки і списку місць -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ЛІВА ПАНЕЛЬ -->

        <ScrollViewer 
            Grid.Column="0" 
            VerticalScrollBarVisibility="Auto" 
            HorizontalScrollBarVisibility="Disabled" 
            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" 
            BorderThickness="0,0,1,0">

            <!-- ТЕКСТБОКСИ: місто, країна, опис -->
            <StackPanel Margin="20" HorizontalAlignment="Stretch">

                <ui:TextBlock Text="Назва міста *" Margin="0,0,0,4" />
                <ui:TextBox x:Name="CityTextBox" 
                            Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}" 
                            PlaceholderText="Львів" 
                            Margin="0,0,0,16"/>

                <ui:TextBlock Text="Країна *" Margin="0,0,0,4" />
                <ui:TextBox x:Name="CountryTextBox" 
                            Text="{Binding NewCountry, UpdateSourceTrigger=PropertyChanged}" 
                            PlaceholderText="Україна" 
                            Margin="0,0,0,16" 
                            AutomationProperties.IsRequiredForForm="True"/>

                <ui:TextBlock Text="Опис *" Margin="0,0,0,4" />
                <ui:TextBox x:Name="DescriptionTextBox" 
                    Text="{Binding NewDescription, UpdateSourceTrigger=PropertyChanged}" 
                    PlaceholderText="Це місто кави, місто тисячі левів,&#x0a;місто джазу, дощу,шоколаду, терас&#x0a;і пристрасного танго." 
                    TextWrapping="Wrap"
                    AcceptsReturn="True"
                    MinHeight="70" 
                    Margin="0,0,0,16"/>

                <ui:TextBlock Text="Примітки" Margin="0,0,0,4" />
                <ui:TextBox x:Name="NotesTextBox" 
                        Text="{Binding NewNotes, UpdateSourceTrigger=PropertyChanged}" 
                        PlaceholderText="Додаткова інформація..." 
                        Margin="0,0,0,16"/>

                <!-- 2 Колонки: Дата + Рейтинг -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Дата -->
                    <StackPanel Grid.Column="0">
                        <ui:TextBlock Text="Дата відвідування" Margin="0,0,0,4"/>
                        <DatePicker x:Name="DatePickerBox" SelectedDate="{Binding NewVisitDate}" HorizontalAlignment="Stretch"/>
                    </StackPanel>

                    <!-- Рейтинг -->
                    <StackPanel Grid.Column="2">
                        <ui:TextBlock Text="Рейтинг" Margin="0,0,0,4"/>
                        <ui:RatingControl x:Name="Rating" Value="{Binding NewRating, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HalfStarEnabled="False"/>
                    </StackPanel>

                </Grid>

            <StackPanel >
                <ui:TextBlock>
                    Тип місця
                </ui:TextBlock>
                <ComboBox
                    Margin="0,0,0,20"
                    ItemsSource="{Binding PlaceTypes}"
                    SelectedItem="{Binding SelectedPlaceType, Mode=TwoWay}" 
                    />
            </StackPanel>

            <!-- Поля для Historical -->
            <StackPanel Visibility="{Binding SelectedPlaceType, Converter={StaticResource PlaceTypeToVisibility}, ConverterParameter=Historical}" Margin="0,0,0,12">
                <ui:TextBlock Text="Рік побудови" Margin="0,0,0,4" />
                <DatePicker SelectedDate="{Binding HistoricalYearBuilt, Mode=TwoWay}" />
                <ui:TextBlock Text="Значимість (1-10)" Margin="0,8,0,4" />
                <TextBox Text="{Binding HistoricalSignificance, Mode=TwoWay}" />
            </StackPanel>

            <!-- Поля для Natural -->
            <StackPanel Visibility="{Binding SelectedPlaceType, Converter={StaticResource PlaceTypeToVisibility}, ConverterParameter=Natural}" Margin="0,0,0,12">
                <ui:TextBlock Text="Рік утворення" Margin="0,0,0,4" />
                <DatePicker SelectedDate="{Binding NaturalYearBuilt, Mode=TwoWay}" />
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <ui:TextBlock Text="Під захистом" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <CheckBox IsChecked="{Binding NaturalProtectedStatus, Mode=TwoWay}" />
                </StackPanel>
            </StackPanel>

                
                <!-- 2 Колонки: "Додати місце" + "Очистити форму" -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- КНОПКА "Додати місце" -->
                    <ui:Button 
                        Grid.Column="0" 
                        HorizontalAlignment="Stretch" 
                        Appearance="Success" 
                        Icon="{ui:SymbolIcon Symbol=Add12}"
                        Command="{Binding AddPlaceCommand}">
                        Додати запис
                    </ui:Button>

                    <!-- КНОПКА "Очистити форму" -->
                    <ui:Button 
                        Grid.Column="2"
                        Appearance="Secondary" 
                        HorizontalAlignment="Stretch" 
                        Icon="{ui:SymbolIcon Symbol=Broom20}"
                        Command="{Binding ClearFormCommand}"
                    />
                </Grid>
                <!-- Примітка: Обов'язкові поля -->
                <ui:TextBlock Opacity="0.6">
                    * - обов'язкові для заповнення поля
                </ui:TextBlock>


                <!-- ІНДЕКСАТОР (скривати/показувати через Expander) -->
                <Expander Header="Пошук за індексом" IsExpanded="False" Margin="0,5,0,8">
                    <StackPanel>
                        <ui:TextBlock Text="Введіть індекс" Margin="0,0,0,4" />
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <ui:NumberBox 
                                Grid.Column="0"
                                Value="{Binding IndexToShow, UpdateSourceTrigger=PropertyChanged}"
                                Minimum="0"
                                HorizontalAlignment="Stretch" />

                            <ui:Button 
                                Grid.Column="2"
                                Appearance="Secondary"
                                Icon="{ui:SymbolIcon Symbol=Search12}"
                                Command="{Binding ShowByIndexCommand}"
                                Padding="12,8" />
                        </Grid>

                        <ui:TextBlock Text="Результат:" Margin="0,0,0,4" Opacity="0.7" FontSize="12" />
                        <TextBlock 
                            Text="{Binding PlaceAtIndexDisplay}"
                            TextWrapping="Wrap"
                            MinHeight="40"
                            Padding="8" />
                    </StackPanel>
                </Expander>

            </StackPanel>
        </ScrollViewer>

        <!-- СПИСОК -->
        <Grid Grid.Column="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- DATAGRID: прив'язка до Places -->
            <ui:DataGrid x:Name="PlacesDataGrid" 
                Grid.Row="0"
                ItemsSource="{Binding Places}" 
                SelectedItem="{Binding SelectedPlace}"
                AutoGenerateColumns="False" 
                IsReadOnly="True"
                SelectionMode="Single"
                HeadersVisibility="Column"
                Margin="0,0,0,16">

                <!-- КОЛОНКИ ДАТАГРІДА -->
                <!-- Назва місця + зірка при рейтингу > 4 -->
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Місто" Width="*" SortMemberPath="NameOfPlace">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon x:Name="StarIcon" 
                                           Symbol="Star12"
                                           Filled="True"
                                           Foreground="#FFD700" 
                                           Margin="0,0,6,0" 
                                           Visibility="Collapsed" />
                                    <TextBlock Text="{Binding NameOfPlace}" VerticalAlignment="Center" />
                                </StackPanel>

                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsHighlyRated}" Value="True">
                                        <Setter TargetName="StarIcon" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>

                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>


                    <!-- КРАЇНА / ОПИС / РЕЙТИНГ / ПРИМІТКИ -->
                    <DataGridTextColumn Header="Країна" Binding="{Binding Country}" Width="*"/>
                    <DataGridTextColumn Header="Опис" Binding="{Binding Description, Mode=OneWay}" Width="1.5*"/>
                    <DataGridTextColumn Header="Дата" Binding="{Binding DateOfVisiting, Mode=TwoWay, StringFormat='{}{0:dd/MM/yyyy}'}" Width="*"/>
                    <DataGridTextColumn Header="Рейтинг" Binding="{Binding Rating, Mode=OneWay}" Width="*"/>
                    <DataGridTextColumn Header="Примітки" Binding="{Binding Notes, Mode=TwoWay}" Width="*"/>
                    <DataGridTextColumn Header="Підсумок подорожі" Binding="{Binding TravelSummary, Mode=OneTime}" Width="*"/>
                </DataGrid.Columns>
            </ui:DataGrid>

            <!-- КНОПКА "Видалити запис" -->
            <ui:Button Grid.Row="1" 
                       Appearance="Danger" 
                       HorizontalAlignment="Right" 
                       Command="{Binding DeletePlaceCommand}"
                       Icon="{ui:SymbolIcon Symbol=Delete24}">
                Видалити обраний запис
            </ui:Button>
        </Grid>
    </Grid>
</Window>